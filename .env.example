# Copiez ce fichier en « .env » (déjà gitignoré). Le serveur le charge au
# démarrage (app/main.py) pour la génération de synthèse (US4.2).

# Mode démo hors-ligne : génère la synthèse par règles, sans IA ni clé ni coût.
# Pratique pour tester le parcours. Mettez à 0 quand vous utilisez une vraie clé.
SYNTHESE_DEMO=0

# Fournisseur IA utilisé pour toute génération (synthèse, recommandations,
# extraction trame/entretien) — un seul actif à la fois. Défaut : anthropic.
# AI_PROVIDER=anthropic   # anthropic | openai | mistral | ollama

# Clé API du fournisseur choisi (une seule à renseigner, selon AI_PROVIDER) :
# ANTHROPIC_API_KEY=sk-ant-...   # https://console.anthropic.com/settings/keys
# OPENAI_API_KEY=sk-...          # https://platform.openai.com/api-keys
# MISTRAL_API_KEY=...            # https://console.mistral.ai/api-keys

# ollama ne prend pas de clé (serveur local, aucune donnée envoyée à
# l'extérieur) — installer Ollama (https://ollama.com), tirer un modèle
# (ex. `ollama pull llama3.1`), puis AI_PROVIDER=ollama. Seul fournisseur qui
# permet l'analyse d'un entretien libre (incr.9) sans IA externe, en
# complément de la transcription déjà locale (Whisper, voir plus bas).
# OLLAMA_HOST=http://localhost:11434   # optionnel, ce défaut convient dans la plupart des cas

# (Optionnel) Modèle utilisé, quel que soit le fournisseur — défaut par
# fournisseur : claude-opus-4-8 (anthropic), gpt-4o (openai),
# mistral-large-latest (mistral), llama3.1 (ollama).
# SYNTHESE_MODEL=claude-opus-4-8

# (Optionnel) Taille du modèle Whisper local pour la transcription audio
# (US3.2, enregistrement d'entretien) — tiny, base, small, medium, large-v3.
# Téléchargé au premier usage. Défaut : medium (relevé de "small" le
# 2026-07-15 — nettement moins d'erreurs sur les noms propres/termes
# techniques, cf. CLAUDE.md). Repli sur small si trop lent au fil de l'eau
# sur ce poste.
# WHISPER_MODEL=medium

# (Optionnel) Largeur de faisceau de la recherche Whisper — 1 (greedy, le
# plus rapide) à ~5. Défaut : 2, un compromis. Sans effet notable au-delà de
# 5 sur la qualité, mais un coût CPU croissant.
# WHISPER_BEAM_SIZE=2
