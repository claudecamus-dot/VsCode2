# Copiez ce fichier en « .env » (déjà gitignoré). Le serveur le charge au
# démarrage (app/main.py) pour la génération de synthèse (US4.2).

# Mode démo hors-ligne : génère la synthèse par règles, sans IA ni clé ni coût.
# Pratique pour tester le parcours. Mettez à 0 quand vous utilisez une vraie clé.
SYNTHESE_DEMO=0

# Fournisseur IA utilisé pour toute génération (synthèse, recommandations,
# extraction trame/entretien) — un seul actif à la fois. Défaut : anthropic.
# AI_PROVIDER=anthropic   # anthropic | openai | mistral

# Clé API du fournisseur choisi (une seule à renseigner, selon AI_PROVIDER) :
# ANTHROPIC_API_KEY=sk-ant-...   # https://console.anthropic.com/settings/keys
# OPENAI_API_KEY=sk-...          # https://platform.openai.com/api-keys
# MISTRAL_API_KEY=...            # https://console.mistral.ai/api-keys

# (Optionnel) Modèle utilisé, quel que soit le fournisseur — défaut par
# fournisseur : claude-opus-4-8 (anthropic), gpt-4o (openai),
# mistral-large-latest (mistral).
# SYNTHESE_MODEL=claude-opus-4-8

# (Optionnel) Taille du modèle Whisper local pour la transcription audio
# (US3.2, enregistrement d'entretien) — tiny, base, small, medium, large-v3.
# Téléchargé au premier usage. Défaut : small
# WHISPER_MODEL=small
